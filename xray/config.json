{
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 7898,
      "protocol": "http",
      "settings": {
        "timeout": 360
      }
    },
    {
      "listen": "0.0.0.0",
      "port": 17898,
      "protocol": "socks",
      "settings": {
        "timeout": 360
      }
    }
  ],
  "log": {
    "loglevel": "debug"
  },
  "outbounds": [
    {
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 7897
          }
        ]
      },
      "tag": "oversea"
    },
    {
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 2080
          }
        ]
      },
      "tag": "coding"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "AsIs",
        "userLevel": 0
      },
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "domain": [
          "domain:srdcloud.cn"
        ],
        "outboundTag": "coding"
      },
      {
        "type": "field",
        "domain": [
          "domain:ctc.com",
          "domain:chinatelecom.com.cn",
          "domain:chinatelecom.cn",
          "full:gitlab.ctyun.cn"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ip": [
          "41.10.255.0/24",
          "203.55.10.36/32",
          "21.57.154.134/32",
          "21.40.0.0/16"
        ],
        "outboundTag": "direct"
      }
    ]
  }
}